# .env.example - copy to .env and fill real values.
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(50))"

# Django
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DEBUG=False
SECURE_SSL_REDIRECT=True

# Database
POSTGRES_DB=educrm
POSTGRES_USER=educrm
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ACCESS_KEY=REPLACE_WITH_STRONG_KEY
MINIO_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=educrm

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Timezone / logging
TIME_ZONE=Asia/Tashkent
LOG_LEVEL=WARNING
