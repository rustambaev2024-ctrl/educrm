# ─── EduCRM · STAGING (пример) ────────────────────────────────────────────
# Реальные значения выставляются в Railway → Environment "staging" → Variables.
# НЕ коммитить реальные секреты. В Railway на сервисы Postgres/Redis
# ссылаться через синтаксис ${{ИмяСервиса.ПЕРЕМЕННАЯ}}.

# Django
DJANGO_SETTINGS_MODULE=config.settings.staging
SECRET_KEY=CHANGE_ME_staging_secret_key
DEBUG=False
LOG_LEVEL=DEBUG

# Хосты и CORS/CSRF — подставить реальные staging-домены после первого деплоя
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=https://educrm-staging-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://educrm-staging-frontend.up.railway.app

# PostgreSQL — этот проект читает РАЗДЕЛЬНЫЕ переменные (НЕ DATABASE_URL!)
# В Railway ссылаться на сервис Postgres staging-окружения:
POSTGRES_DB=${{Postgres.PGDATABASE}}
POSTGRES_USER=${{Postgres.PGUSER}}
POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}
POSTGRES_HOST=${{Postgres.PGHOST}}
POSTGRES_PORT=${{Postgres.PGPORT}}

# Redis (Celery broker/result + channels)
REDIS_URL=${{Redis.REDIS_URL}}

# Медиа — постоянный Railway Volume, смонтированный на этот путь
MEDIA_ROOT=/app/media

# HTTPS-редирект отключён на staging (Railway отдаёт https на edge)
SECURE_SSL_REDIRECT=False
